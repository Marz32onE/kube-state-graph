{
  "title": "kube-state-graph — multi-cluster pod graph",
  "schemaVersion": 39,
  "uid": "kube-state-graph-nodegraph",
  "tags": ["kube-state-graph", "node-graph"],
  "timezone": "browser",
  "time": {"from": "now-15m", "to": "now"},
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "nodeGraph",
      "title": "Pod graph (multi-cluster)",
      "description": "Renders /v1/graph/nodegraph from kube-state-graph via Infinity datasource. Two queries (refId nodes + edges) feed Grafana's NodeGraph panel — Grafana resolves them by refId match.",
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "kube-state-graph"},
      "targets": [
        {
          "refId": "nodes",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "/v1/graph/nodegraph?start=${__from:date:seconds}&end=${__to:date:seconds}",
          "url_options": {"method": "GET", "data": ""},
          "parser": "backend",
          "root_selector": "nodes",
          "columns": [
            {"selector": "id",       "text": "id",       "type": "string"},
            {"selector": "title",    "text": "title",    "type": "string"},
            {"selector": "subTitle", "text": "subTitle", "type": "string"},
            {"selector": "mainStat", "text": "mainStat", "type": "string"}
          ]
        },
        {
          "refId": "edges",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "/v1/graph/nodegraph?start=${__from:date:seconds}&end=${__to:date:seconds}",
          "url_options": {"method": "GET", "data": ""},
          "parser": "backend",
          "root_selector": "edges",
          "columns": [
            {"selector": "id",       "text": "id",       "type": "string"},
            {"selector": "source",   "text": "source",   "type": "string"},
            {"selector": "target",   "text": "target",   "type": "string"},
            {"selector": "mainStat", "text": "mainStat", "type": "string"}
          ]
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 20}
    }
  ]
}
